datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Agent {
  id         Int       @id @default(autoincrement())
  name       String
  email      String    @unique
  properties Property[]
}

model Property {
  id            Int      @id @default(autoincrement())
  title         String
  description   String
  price         Int
  beds          Int
  baths         Int
  suburb        String
  type          String
  agentId       Int
  agent         Agent    @relation(fields: [agentId], references: [id])
  internalNotes String?
  createdAt     DateTime @default(now())

  @@index([price])
  @@index([suburb])
  @@index([type])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}